# Copia este archivo a ".env" y completa tu API key.
#
# Conseguila gratis en: https://dashboard.api-football.com/register
# (plan Free: ~100 peticiones por dia, suficiente para uso personal con la cache incluida)
#
# Si dejas APIFOOTBALL_KEY vacio, la app igual arranca en MODO DEMO con datos ficticios.

APIFOOTBALL_KEY=tu_api_key_aca

PORT=3000

# Opcionales (calibracion del modelo). Si no los pones, se usan los valores por defecto.
# Ventaja de local: en el Mundial las canchas son neutrales, por eso 0 por defecto.
HOME_ADVANTAGE=0
# Pesos calibrados por backtest (npm run tune): la calidad/Elo manda y la forma reciente casi
# no pesa (el rating ya incluye recencia). Editables; los sliders de la web hacen lo mismo en vivo.
# Peso de la forma reciente (ultimos 5).
FORM_WEIGHT=0.05
# Peso del historial directo (head-to-head).
H2H_WEIGHT=0.20
# Cuanto pondera la CALIDAD DEL RIVAL al promediar partidos pasados (0=no importa; puede ser >1).
# Asi, golearle a una potencia vale mas que golearle a un equipo flojo.
OPPONENT_WEIGHT=1.0
# Peso directo de la diferencia de rating entre los dos equipos sobre los goles esperados.
# Subir = la calidad pesa más (el favorito mete más, el débil menos). Bajar para suavizar.
RATING_WEIGHT=0.90
# Correccion Dixon-Coles para marcadores bajos (rho, negativo). Sube empates 0-0/1-1.
# Calibrado por backtest (npm run backtest); 0 = Poisson puro sin correccion.
DC_RHO=-0.05
# Temperatura de calibracion de las probabilidades W/D/L (>1 suaviza, <1 agudiza).
# Calibrada con npm run tune:elo; 1 = sin cambio (el modelo ya esta bien calibrado).
PROB_TEMP=1.0
# Cuantos partidos recientes mirar para forma/goles.
RECENT_MATCHES=10
# Cuantos partidos recientes mirar para stats detalladas (tarjetas, tiros, etc). Cuesta 1 peticion c/u.
STATS_MATCHES=3
# Temporadas a consultar (mas reciente primero). El plan Free de API-Football NO admite el
# parametro "last" y cubre datos SOLO hasta la temporada 2024, por eso pedimos por temporada
# y combinamos (2024 es lo mas reciente posible en el plan Free; 2025+ requiere plan pago).
SEASONS=2024,2023

# --- Datos actuales 2026 (overlay sobre API-Football) -------------------------------
# La base es API-Football season=2024 (selecciones, hasta ~ago-2025). El plan Free ademas
# permite una ventana movil de ~3 dias (ayer/hoy/manana) via `date`, que durante el Mundial
# trae partidos de 2026 CON stats completas. Sobre eso se superpone el ultimo partido + el
# proximo rival desde una fuente intercambiable:
#   hybrid           -> API-Football-live (stats completas) + TheSportsDB de respaldo (default)
#   apifootball-live -> solo la ventana de fechas de API-Football
#   thesportsdb      -> solo TheSportsDB (gratis, sin registro)
#   rapidapi         -> soccer-data6 (necesita RAPIDAPI_KEY)
#   apifootball      -> sin overlay (solo la base)
DATA_SOURCE=hybrid
# TheSportsDB: la key publica de demo "3" alcanza para el respaldo (ultimo partido + proximo).
THESPORTSDB_KEY=3
# soccer-data6 (RapidAPI), OPCIONAL. Vacio = desactivado. Para activarlo: crea cuenta en
# RapidAPI, suscribite al plan de soccer-data6, pega tu key y confirma el host del panel.
RAPIDAPI_KEY=
RAPIDAPI_HOST=soccer-data6.p.rapidapi.com

# --- Fuente primaria: dataset de resultados (martj42/international_results) ----------
# ON por defecto. Bajá el dataset una vez con:  npm run import:intl
# (escribe data/international_results.csv: goles/forma/H2H/resultados 2026 sin tocar la API).
# Las stats detalladas (tarjetas/tiros/corners) no estan en el repo: se traen con el boton
# "Consultar API" en la pantalla. Poné USE_INTL=0 para volver a la API/dataset live.
USE_INTL=1

# --- Modelo Dixon-Coles de ataque/defensa (MLE) -------------------------------------
# ON por defecto. Los goles esperados (lambdas) salen de fuerzas ataque/defensa ajustadas por
# maxima verosimilitud sobre todo el historial (data/dcParams.json), en vez de la receta
# heuristica (promedios + multiplicadores de forma/H2H/rating). Validado por backtest:
# log-loss 1.053 -> 0.996 y accuracy 48% -> 54% (npm run fit:dc). Regeneralo con:
#   npm run fit:dc -- --write      (compara contra el heuristico y escribe data/dcParams.json)
# Con USE_DC_MODEL=0 vuelve al modelo heuristico (y ahi si pesan los sliders/pesos de abajo).
USE_DC_MODEL=1

# --- Cuotas del mercado (blend offline) ---------------------------------------------
# Si data/odds.json existe (snapshot bajado a mano con `npm run import:odds`), el modelo mezcla su
# 1X2 con las cuotas del mercado (el predictor mejor calibrado). La WEB NUNCA consume la API: solo
# lee el snapshot. El snapshot se baja corriendo el import cuando haga falta (fase de grupos ahora;
# despues, cuando se definan los cruces de eliminatorias). Solo el import usa la key.
#   npm run import:odds            (baja cuotas 1X2 de The Odds API -> data/odds.json + docs/data/)
# Key gratis (~500 req/mes) en https://the-odds-api.com. Cada import cuesta 1 credito.
ODDS_API_KEY=
# Cuanto pesa el mercado en la mezcla (0..1). 0.6 = 60% mercado / 40% modelo. USE_ODDS=0 lo apaga.
USE_ODDS=1
ODDS_WEIGHT=0.6

# --- Dataset local por API (CSV) ----------------------------------------------------
# Alternativa secundaria: snapshot armado pegandole a la API (incluye stats). Con USE_DATASET=1
# la app consume data/teams.csv + data/matches.csv. Se genera con:  npm run build:dataset
USE_DATASET=0

# --- Recordatorio por email 2h antes de cada partido (npm run notify) ---------------
# Manda un mail con la imagen de "resultados posibles" 2h antes del kickoff de cada partido
# cargado en data/fixtures.json. Corre solo via GitHub Actions (.github/workflows/notify-matches.yml);
# para probar local se leen estas vars. NUNCA poner valores reales en este archivo de ejemplo:
# van en tu .env (gitignored) y en GitHub Secrets para el workflow.
# Gmail: activa 2FA y genera una "Contraseña de aplicacion" (NO tu clave real) en
# https://myaccount.google.com/apppasswords  -> esa va en SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_app_password_de_16_letras
# A quien llega el recordatorio (puede ser el mismo correo).
MAIL_TO=tu_correo@gmail.com
